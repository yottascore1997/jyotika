generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model StockSet {
  id                    Int      @id @default(autoincrement())
  setId                 String   @unique
  mainSerialNumber      String?  @unique
  modelNumber           String
  make                  String?
  oemSupplier           String
  materialType          String
  category              String
  receivedDate          DateTime
  warrantyStatus        String   @default("Active")
  poNumber              String?
  purchaseCost          Decimal  @default(0) @db.Decimal(12, 2)
  currentStatus         String   @default("Available")
  currentHolder         String   @default("Store")
  location              String   @default("Main Store")
  remarks               String?  @db.Text
  quantity              Int      @default(1)
  quantityUnit          String   @default("set")
  purpose               String?
  commercialInvoiceNo   String?
  commercialInvoiceDate DateTime?
  awbNumber             String?
  workingCondition      String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  items StockMaster[]

  @@index([currentStatus])
  @@index([mainSerialNumber])
}

model StockMaster {
  id             Int      @id @default(autoincrement())
  stockId        String   @unique
  materialType   String
  oemSupplier    String
  make           String?
  modelNumber    String
  serialNumber   String   @unique
  description    String?  @db.Text
  category       String
  receivedDate   DateTime
  warrantyStatus String   @default("Active")
  poNumber       String?
  purchaseCost   Decimal  @default(0) @db.Decimal(12, 2)
  currentStatus  String   @default("Available")
  currentHolder  String   @default("Store")
  location       String   @default("Main Store")
  remarks        String?  @db.Text
  quantity       Int      @default(1)
  quantityUnit   String   @default("set")
  purpose        String?
  commercialInvoiceNo   String?
  commercialInvoiceDate DateTime?
  awbNumber      String?
  workingCondition String?
  stockSetId     Int?
  stockSet       StockSet? @relation(fields: [stockSetId], references: [id], onDelete: Cascade)
  partRole       String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  movements StockMovement[]
  receipt   MaterialReceipt?
  issues    MaterialIssue[]
  demos     DemoTracking[]
  handovers CustomerHandover[]
  repairs   RepairCase[]
  services  ServiceRecord[]
  oemReturns OEMReturn[]
  sales     AssetSale[]
  poAllocations POSerialAllocation[]
  images         StockImage[]

  @@index([currentStatus])
  @@index([category])
  @@index([materialType])
  @@index([stockSetId])
}

model StockImage {
  id            Int         @id @default(autoincrement())
  stockMasterId Int
  stockMaster   StockMaster @relation(fields: [stockMasterId], references: [id], onDelete: Cascade)
  filePath      String
  fileName      String
  sortOrder     Int         @default(0)
  createdAt     DateTime    @default(now())

  @@index([stockMasterId])
}

model MaterialReceipt {
  id                  Int         @id @default(autoincrement())
  grnNumber           String      @unique
  receivedDate        DateTime
  supplierOem         String
  materialDescription String
  modelNumber         String
  serialNumber        String      @unique
  quantity            Int         @default(1)
  materialType        String
  receivedBy          String
  poNumber            String?
  remarks             String?     @db.Text
  stockMasterId       Int         @unique
  stockMaster         StockMaster @relation(fields: [stockMasterId], references: [id])
  createdAt           DateTime    @default(now())
}

model MaterialIssue {
  id                  Int         @id @default(autoincrement())
  issueNumber         String      @unique
  issueDate           DateTime
  serialNumber        String
  materialDescription String
  issuedTo            String
  customerName        String?
  purpose             String
  expectedReturnDate  DateTime?
  actualReturnDate    DateTime?
  status              String      @default("Issued")
  remarks             String?     @db.Text
  stockMasterId       Int
  stockMaster         StockMaster @relation(fields: [stockMasterId], references: [id])
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  @@index([stockMasterId])
  @@index([serialNumber])
}

model DemoTracking {
  id                 Int         @id @default(autoincrement())
  demoId             String      @unique
  serialNumber       String
  model              String
  salesPerson        String
  customer           String?
  issueDate          DateTime
  expectedReturnDate DateTime?
  actualReturnDate   DateTime?
  status             String      @default("Active")
  remarks            String?     @db.Text
  stockMasterId      Int
  stockMaster        StockMaster @relation(fields: [stockMasterId], references: [id])
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  @@index([stockMasterId])
  @@index([status])
}

model CustomerHandover {
  id                 Int         @id @default(autoincrement())
  customerName       String
  customerCompany    String?
  serialNumber       String
  handoverDate       DateTime
  expectedReturnDate DateTime?
  actualReturnDate   DateTime?
  status             String      @default("Active")
  remarks            String?     @db.Text
  stockMasterId      Int
  stockMaster        StockMaster @relation(fields: [stockMasterId], references: [id])
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  @@index([stockMasterId])
}

model RepairCase {
  id                    Int         @id @default(autoincrement())
  repairId              String      @unique
  serialNumber          String
  customerName          String
  complaint             String      @db.Text
  receivedDate          DateTime
  repairStartDate       DateTime?
  repairCompletionDate  DateTime?
  returnDate            DateTime?
  status                String      @default("Received")
  remarks               String?     @db.Text
  stockMasterId         Int
  stockMaster           StockMaster @relation(fields: [stockMasterId], references: [id])
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt

  @@index([stockMasterId])
  @@index([status])
}

model ServiceRecord {
  id              Int         @id @default(autoincrement())
  serviceId       String      @unique
  serialNumber    String
  customerName    String
  serviceType     String
  serviceDate     DateTime
  completionDate  DateTime?
  status          String      @default("Pending")
  description     String?     @db.Text
  remarks         String?     @db.Text
  stockMasterId   Int
  stockMaster     StockMaster @relation(fields: [stockMasterId], references: [id])
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([stockMasterId])
  @@index([serialNumber])
  @@index([status])
}

model OEMReturn {
  id            Int         @id @default(autoincrement())
  returnId      String      @unique
  oemName       String
  serialNumber  String
  returnDate    DateTime
  reason        String      @db.Text
  status        String      @default("Pending")
  remarks       String?     @db.Text
  stockMasterId Int
  stockMaster   StockMaster @relation(fields: [stockMasterId], references: [id])
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([stockMasterId])
  @@index([status])
}

model AssetSale {
  id            Int         @id @default(autoincrement())
  invoiceNumber String      @unique
  customer      String
  serialNumber  String
  saleDate      DateTime
  amount        Decimal     @default(0) @db.Decimal(12, 2)
  stockMasterId Int
  stockMaster   StockMaster @relation(fields: [stockMasterId], references: [id])
  createdAt     DateTime    @default(now())

  @@index([stockMasterId])
}

model POMaster {
  id                   Int      @id @default(autoincrement())
  poId                 String   @unique
  clientName           String
  location             String
  poNumber             String
  poDate               DateTime
  orderType            String
  salesPerson          String
  itemDescription      String
  serialNumber         String?
  quantityOrdered      Int      @default(1)
  unitValue            Decimal  @default(0) @db.Decimal(12, 2)
  totalPoValue         Decimal  @default(0) @db.Decimal(12, 2)
  advanceRequired      Boolean  @default(false)
  advanceReceived      Boolean  @default(false)
  expectedDeliveryDate DateTime?
  status               String   @default("PO")
  remarks              String?  @db.Text
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  serialAllocations POSerialAllocation[]
  images             POImage[]

  @@index([status])
  @@index([clientName])
}

model POImage {
  id         Int      @id @default(autoincrement())
  poMasterId Int
  poMaster   POMaster @relation(fields: [poMasterId], references: [id], onDelete: Cascade)
  filePath   String
  fileName   String
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())

  @@index([poMasterId])
}

model POSerialAllocation {
  id            Int         @id @default(autoincrement())
  poMasterId    Int
  poMaster      POMaster    @relation(fields: [poMasterId], references: [id], onDelete: Cascade)
  model         String
  serialNumber  String
  stockType     String      @default("New Stock")
  status        String      @default("Reserved")
  stockMasterId Int
  stockMaster   StockMaster @relation(fields: [stockMasterId], references: [id])
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@unique([poMasterId, serialNumber])
  @@index([poMasterId])
  @@index([serialNumber])
  @@index([status])
}

model StockMovement {
  id            Int         @id @default(autoincrement())
  movementId    String      @unique
  serialNumber  String
  date          DateTime    @default(now())
  fromLocation  String
  toLocation    String
  movementType  String
  user          String      @default("Admin")
  remarks       String?     @db.Text
  stockMasterId Int
  stockMaster   StockMaster @relation(fields: [stockMasterId], references: [id])
  createdAt     DateTime    @default(now())

  @@index([stockMasterId])
  @@index([serialNumber])
  @@index([date])
}

model Tender {
  id                   Int      @id @default(autoincrement())
  organizationName     String
  location             String
  tenderBidNo          String
  tenderSubmittedDate  DateTime
  quotedProduct        String
  orderValue           Decimal  @default(0) @db.Decimal(12, 2)
  status               String   @default("Tender Filled Up")
  statusAsOnDate       String   @db.Text
  fixedRa              String   @default("No")
  miiPreference        String   @default("No")
  tenderType           String   @default("Standard")
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  documents TenderDocument[]

  @@index([organizationName])
  @@index([tenderSubmittedDate])
  @@index([status])
}

model TenderDocument {
  id        Int      @id @default(autoincrement())
  tenderId  Int
  tender    Tender   @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  docType   String
  filePath  String
  fileName  String
  fileSize  Int      @default(0)
  createdAt DateTime @default(now())

  @@unique([tenderId, docType])
  @@index([tenderId])
}
